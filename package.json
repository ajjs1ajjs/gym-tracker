{
  "name": "gym-tracker",
  "version": "3.0.0",
  "description": "Progressive Web App for workout tracking with exercise library, progress tracking, and workout plans",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:sw-cache",
    "build:ts": "tsc",
    "build:legacy": "npm run build:ts && shx mkdir -p dist/images && shx cp images/* dist/images/ && shx cp style.css dist/ && shx cp index.html dist/ && shx cp sw.js dist/ && shx cp manifest.json dist/ && node fix-paths.js && npm run build:sw-cache",
    "build:sw-cache": "node generate-sw-cache.js",
    "clean": "shx rm -rf dist",
    "preview": "vite preview",
    "start": "vite",
    "rebuild": "npm run clean && npm run build",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "format": "prettier --write \"**/*.{js,jsx,json,md,ts,css,html}\"",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests"
  },
  "keywords": [
    "gym",
    "fitness",
    "workout",
    "tracking",
    "pwa",
    "exercise"
  ],
  "author": "ajjs1ajjs",
  "license": "MIT",
  "devDependencies": {
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-typescript": "^7.24.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "babel-jest": "^29.7.0",
    "chart.js": "^4.5.1",
    "cypress": "^15.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ajjs1ajjs/gym-tracker.git"
  },
  "bugs": {
    "url": "https://github.com/ajjs1ajjs/gym-tracker/issues"
  },
  "homepage": "https://github.com/ajjs1ajjs/gym-tracker#readme"
}
